# === Sentinel Bot Configuration ===

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Your Telegram User ID (only this user can interact with the bot)
# Find yours by messaging @userinfobot on Telegram
ALLOWED_USER_IDS=

# OpenRouter API Key (from https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# OpenRouter Model ID (e.g. anthropic/claude-sonnet-4, google/gemini-2.5-pro, etc.)
OPENROUTER_MODEL_ID=anthropic/claude-sonnet-4

# OpenAI API Key — used for Whisper voice transcription
OPENAI_API_KEY=

# ElevenLabs API Key — used for text-to-speech voice replies (optional)
# If not set, voice messages will be transcribed and answered with text only.
ELEVENLABS_API_KEY=

# ElevenLabs Voice ID (default: Rachel — a calm, clear voice)
# Browse voices at https://elevenlabs.io/voice-library
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Max agentic loop iterations (safety limit, default: 10)
MAX_TOOL_ITERATIONS=10
